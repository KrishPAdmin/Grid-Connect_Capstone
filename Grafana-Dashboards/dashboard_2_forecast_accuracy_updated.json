          "query": "import \"math\"\nimport \"date\"\n\na = from(bucket: \"simulations\")\n  |> range(start: -7d, stop: now())\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http\")\n  |> filter(fn: (r) => r[\"_field\"] == \"wind_power\")\n  |> filter(fn: (r) => r[\"source\"] == \"powersim3.0\")\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false, timeSrc: \"_start\")\n  |> keep(columns: [\"_time\", \"_value\"])\n\nf = from(bucket: \"forecast\")\n  |> range(start: -7d, stop: now())\n  |> filter(fn: (r) => r[\"_measurement\"] == \"forecast_wind_series\")\n  |> filter(fn: (r) => r[\"_field\"] == \"PredictedValue\")\n  |> filter(fn: (r) => r[\"model\"] == \"live_combined_v1\")\n  |> filter(fn: (r) => r[\"horizon\"] == \"1h\")\n  |> aggregateWindow(every: 1h, fn: last, createEmpty: false, timeSrc: \"_start\")\n  |> keep(columns: [\"_time\", \"_value\"])\n\njoin(tables: {a: a, f: f}, on: [\"_time\"])\n  |> map(fn: (r) => ({_time: r._time, _value: math.abs(x: r._value_a - r._value_f), hour: date.hour(t: r._time)}))\n  |> group(columns: [\"hour\"])\n  |> mean()\n  |> group()\n  |> sort(columns: [\"hour\"])\n  |> map(fn: (r) => ({hour: string(v: r.hour), MAE: r._value}))",

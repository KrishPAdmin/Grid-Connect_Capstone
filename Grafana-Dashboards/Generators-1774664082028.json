        {
          "datasource": {
            "type": "influxdb",
            "uid": "bff5gy8tz2lfka"
          },
          "query": "actual = from(bucket: \"simulations\")\r\n  |> range(start: v.timeRangeStart, stop: now())\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"http\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"solar_power\" or r[\"_field\"] == \"wind_power\")\r\n  |> filter(fn: (r) => r[\"source\"] == \"powersim3.0\")\r\n  |> filter(fn: (r) => r[\"url\"] == \"http://powersim:3001/api\")\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false, timeSrc: \"_start\")\r\n  |> pivot(rowKey: [\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> map(fn: (r) => ({_time: r._time, _value: float(v: r.solar_power) + float(v: r.wind_power), series_name: \"Actual Generation\"}))\r\n\r\nforecast = from(bucket: \"forecast\")\r\n  |> range(start: v.timeRangeStart, stop: now())\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"forecast_total_renewable_series\")\r\n  |> filter(fn: (r) => r[\"_field\"] == \"PredictedValue\")\r\n  |> filter(fn: (r) => r[\"model\"] == \"live_combined_v1\")\r\n  |> filter(fn: (r) => r[\"horizon\"] == \"1h\")\r\n  |> aggregateWindow(every: 1h, fn: mean, createEmpty: false, timeSrc: \"_start\")\r\n  |> set(key: \"series_name\", value: \"Forecasted Generation\")\r\n\r\nunion(tables: [actual, forecast])\r\n  |> keep(columns: [\"_time\", \"_value\", \"series_name\"])\r\n  |> group(columns: [\"series_name\"])",
          "refId": "A"
        }
      ],
      "title": "Actual Generation vs. Forecasted Generation",
